APP_NAME="King Gitar"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ==== DATABASE (provided by Railway MySQL plugin) ====
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

# ==== GOOGLE OAUTH ====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://your-app.up.railway.app/auth/google/callback

# ==== GROQ AI (Chatbot) ====
GROQ_API_KEY=

# ==== SCRAMBLE DOCS TOKEN ====
SCRAMBLE_TOKEN=ganti-dengan-token-rahasia-kamu

# ==== SANCTUM ====
SANCTUM_STATEFUL_DOMAINS=your-app.up.railway.app